# Copy to config.ini next to the app binary, or set env var GOOGLE_MAPS_API_KEY.
# Optional: only for "Plan (Google)" — enable Geocoding API + Directions API on the key.
# Maps JavaScript API is NOT required (the app map uses OpenStreetMap + Leaflet).
# Restrict keys appropriately; Qt WebEngine may use non-browser referrers — use IP / app restrictions as supported.

GOOGLE_MAPS_API_KEY=your_key_here

# Optional: folder containing STOP_BUS.csv, ROUTE_BUS.csv, RSTOP_BUS.csv (HK TD open data).
# If unset, the app walks up from the executable looking for Data/Bus,MiniBus,Tram/CSV.
# DATA_CSV_DIR=/absolute/path/to/Mapper/Data/Bus,MiniBus,Tram/CSV
